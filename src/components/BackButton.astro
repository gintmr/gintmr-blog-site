---
import IconChevronLeft from "@/assets/icons/IconChevronLeft.svg";
import LinkButton from "./LinkButton.astro";
import { SITE } from "@/config";
import { UI } from "@/i18n/ui";
---

{
  SITE.showBackButton && (
    <div class="mx-auto flex w-full max-w-app items-center justify-start px-2">
      <LinkButton
        id="back-button"
        href="/"
        class="focus-outline mt-8 mb-2 flex hover:text-foreground/75"
      >
        <IconChevronLeft class="inline-block size-6 rtl:rotate-180" />
        <span>{UI.common.back}</span>
      </LinkButton>
    </div>
  )
}

<script>
  const initBackButton = () => {
    const backButton = document.getElementById("back-button");
    if (!backButton) return;
    if (backButton.dataset.backBound === "true") return;
    backButton.dataset.backBound = "true";

    const readStack = () => {
      try {
        return JSON.parse(sessionStorage.getItem("lastPages") || "[]");
      } catch {
        return [];
      }
    };
    const writeStack = (arr: string[]) => {
      // 只保留最近 10 条
      const pruned = arr.slice(-10);
      sessionStorage.setItem("lastPages", JSON.stringify(pruned));
    };

    const currentBase = () => location.pathname + location.search;
    const normalizeSameOriginReferrer = () => {
      try {
        const ref = document.referrer;
        if (!ref) return "";
        const refUrl = new URL(ref);
        if (refUrl.origin !== location.origin) return "";
        return `${refUrl.pathname}${refUrl.search}`;
      } catch {
        return "";
      }
    };

    const goWithFallback = target => {
      if (target && target !== currentBase()) {
        location.assign(target);
        return true;
      }
      return false;
    };

    // 监听返回按钮点击事件
    backButton.addEventListener("click", function (e) {
      e.preventDefault();

      const stack = readStack();
      const cur = currentBase();

      let targetIndex = -1;
      for (let i = stack.length - 1; i >= 0; i--) {
        if (stack[i] !== cur) {
          targetIndex = i;
          break;
        }
      }

      if (targetIndex >= 0) {
        const target = stack[targetIndex];

        const newStack = stack.slice(0, targetIndex + 1);
        writeStack(newStack);

        if (goWithFallback(target)) return;
      }

      const referrerTarget = normalizeSameOriginReferrer();
      if (goWithFallback(referrerTarget)) return;

      // 再兜底用浏览器 history（某些直达场景 history 可能不可用）
      if (window.history.length > 1) {
        const before = currentBase();
        window.history.back();
        window.setTimeout(() => {
          if (currentBase() === before) {
            location.assign("/");
          }
        }, 350);
        return;
      }

      // 最终兜底：回首页
      location.assign("/");
    });
  };

  document.addEventListener("astro:page-load", initBackButton);
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initBackButton, { once: true });
  } else {
    initBackButton();
  }
</script>
