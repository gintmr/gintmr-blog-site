---
import { slugifyStr } from "@/utils/slugify";
import type { CollectionEntry } from "astro:content";
import { getPath } from "@/utils/getPath";
import Datetime from "./Datetime.astro";
import { optimizeImage } from "@/utils/optimizeImages";

export interface Props extends CollectionEntry<"blog"> {
  variant?: "feature" | "stream";
  eyebrow?: string;
}

const { variant = "stream", eyebrow, data, id, filePath } = Astro.props;

const { title, description, pubDatetime, modDatetime, timezone } = data;
let cardImageSrc: string | undefined;

if (typeof data.ogImage === "string" && data.ogImage.trim()) {
  const optimized = await optimizeImage(data.ogImage, {
    thumbnailSize: variant === "feature" ? 1200 : 720,
  });
  cardImageSrc = optimized.thumbnail;
} else if (
  data.ogImage &&
  typeof data.ogImage === "object" &&
  "src" in data.ogImage &&
  typeof data.ogImage.src === "string"
) {
  cardImageSrc = data.ogImage.src;
}

const href = getPath(id, filePath);
const headingTag = variant === "feature" ? "h2" : "h3";
const defaultEyebrow = variant === "feature" ? "Lead Essay" : "Field Note";
---

<li class:list={["blog-card", `blog-card--${variant}`]}>
  <article class="blog-card__frame">
    <a
      href={href}
      class="blog-card__media"
      aria-label={title}
      transition:name={slugifyStr(title)}
    >
      {
        cardImageSrc ? (
          <img
            src={cardImageSrc}
            alt={title}
            width={1200}
            height={800}
            class="blog-card__image"
            loading="lazy"
            decoding="async"
          />
        ) : (
          <div class="blog-card__image blog-card__image--fallback" aria-hidden="true">
            <span>{title.slice(0, 1)}</span>
          </div>
        )
      }
      <div class="blog-card__media-glow" aria-hidden="true"></div>
    </a>

    <div class="blog-card__content">
      <p class="blog-card__eyebrow">{eyebrow ?? defaultEyebrow}</p>
      <a href={href} class="blog-card__title-link">
        {
          headingTag === "h2" ? (
            <h2 class="blog-card__title">{title}</h2>
          ) : (
            <h3 class="blog-card__title">{title}</h3>
          )
        }
      </a>

      <div class="blog-card__meta">
        <Datetime
          pubDatetime={pubDatetime}
          modDatetime={modDatetime}
          timezone={timezone}
          class="blog-card__datetime"
        />
      </div>

      <p class="blog-card__description">{description}</p>

      <div class="blog-card__footer">
        <a href={href} class="blog-card__cta">
          Read entry
        </a>
      </div>
    </div>
  </article>
</li>
