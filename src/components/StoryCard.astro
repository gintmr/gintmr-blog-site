---
import type { CollectionEntry } from "astro:content";
import dayjs from "dayjs";
import utc from "dayjs/plugin/utc";
import timezone from "dayjs/plugin/timezone";
import { SITE } from "@/config";
import { getStoryPath, getStoryTitle } from "@/utils/getStoryPath";
import { resolveStoryVideoUrlByEntry } from "@/utils/storyVideo";

export interface Props extends CollectionEntry<"story"> {}

dayjs.extend(utc);
dayjs.extend(timezone);

const { data, id, filePath } = Astro.props;
const { title, description, pubDatetime, modDatetime } = data;

const storyTitle = getStoryTitle(title, id, filePath);
const storyPath = getStoryPath(id, filePath);
const storyVideoSrc = resolveStoryVideoUrlByEntry(id, filePath);
const dateLabel = dayjs(modDatetime ?? pubDatetime)
  .tz(SITE.timezone)
  .format("MM-DD");
---

<li class="story-wall__item">
  <a
    href={storyPath}
    class="story-wall-card group block overflow-hidden rounded-xl border border-border/70 bg-background/65 no-underline transition-all hover:-translate-y-0.5 hover:border-accent/45"
  >
    <div class="story-wall-card__media relative aspect-[3/4] overflow-hidden bg-black">
      {
        storyVideoSrc ? (
          <video
            src={`${storyVideoSrc}#t=0.1`}
            preload="metadata"
            muted
            playsinline
            class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-[1.02]"
          />
        ) : (
          <div class="flex h-full w-full items-center justify-center text-xs text-foreground/55">
            Video not found
          </div>
        )
      }
      <span class="story-wall-card__play-badge">▶</span>
    </div>

    <div class="p-3">
      <h2 class="line-clamp-2 text-base font-semibold leading-tight text-foreground">
        {storyTitle}
      </h2>
      <p class="mt-2 text-sm text-foreground/72">{dateLabel}</p>
      {
        description?.trim() && (
          <p class="mt-1 line-clamp-2 text-xs text-foreground/58">{description}</p>
        )
      }
    </div>
  </a>
</li>
