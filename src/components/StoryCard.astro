---
import type { CollectionEntry } from "astro:content";
import dayjs from "dayjs";
import utc from "dayjs/plugin/utc";
import timezone from "dayjs/plugin/timezone";
import { SITE } from "@/config";
import { getStoryPath, getStoryTitle } from "@/utils/getStoryPath";
import { resolveStoryVideoUrlByEntry } from "@/utils/storyVideo";

export interface Props extends CollectionEntry<"story"> {}

dayjs.extend(utc);
dayjs.extend(timezone);

const { data, id, filePath } = Astro.props;
const { title, description, pubDatetime } = data;

const storyTitle = getStoryTitle(title, id, filePath);
const storyPath = getStoryPath(id, filePath);
const storyVideoSrc = resolveStoryVideoUrlByEntry(id, filePath);
const dateLabel = dayjs(pubDatetime)
  .tz(SITE.timezone)
  .format("YYYY-MM-DD");
---

<li class="story-wall__item">
  <a
    href={storyPath}
    class="story-wall-card group block no-underline"
  >
    <div class="story-wall-card__media relative aspect-[3/4] overflow-hidden bg-black">
      {
        storyVideoSrc ? (
          <video
            src={`${storyVideoSrc}#t=0.1`}
            preload="none"
            muted
            playsinline
            data-story-card-video
            class="story-wall-card__video h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.025]"
          />
        ) : (
          <div class="story-wall-card__fallback flex h-full w-full items-center justify-center text-xs text-foreground/55">
            Video not found
          </div>
        )
      }
      <div class="story-wall-card__veil"></div>
      <div class="story-wall-card__headline">
        <span class="story-wall-card__headline-date">{dateLabel}</span>
        <h2 class="story-wall-card__headline-title">{storyTitle}</h2>
      </div>
      <span class="story-wall-card__play-badge">▶</span>
    </div>

    <div class="story-wall-card__copy p-3">
      <p class="story-wall-card__meta">{dateLabel}</p>
      {
        description?.trim() && (
          <p class="story-wall-card__desc mt-1 line-clamp-2 text-xs text-foreground/58">{description}</p>
        )
      }
    </div>
  </a>
</li>
