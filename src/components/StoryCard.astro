---
import fs from "node:fs";
import path from "node:path";
import type { CollectionEntry } from "astro:content";
import Datetime from "./Datetime.astro";
import {
  getStoryFolderRelative,
  getStoryPath,
  getStoryTitle,
} from "@/utils/getStoryPath";
import { optimizeImage } from "@/utils/optimizeImages";
import { getCoverPath } from "@/utils/audioUtils";
import {
  normalizeStoryAssetPath,
  resolveStoryImageAssetUrl,
} from "@/utils/storyAssetResolver";
import { SITE } from "@/config";

export interface Props extends CollectionEntry<"story"> {}

const { data, id, filePath } = Astro.props;
const { title, description, pubDatetime, modDatetime, cover, slides } = data;
const storyTitle = getStoryTitle(title, id, filePath);
const storyDirRelative = `story/${getStoryFolderRelative(id, filePath)}`;
let storySlideCount = slides?.length ?? 0;

let coverSrc: string | undefined;
let coverRawPath = cover?.trim()
  ? normalizeStoryAssetPath(cover, storyDirRelative)
  : "";

if (!coverRawPath && slides?.length) {
  const firstSlideMedia = slides[0]?.media;
  if (firstSlideMedia) {
    coverRawPath = normalizeStoryAssetPath(firstSlideMedia, storyDirRelative);
  }
}

if (!coverRawPath) {
  const imgsDirAbs = path.resolve(process.cwd(), "src/data", storyDirRelative, "imgs");
  if (fs.existsSync(imgsDirAbs)) {
    const files = fs
      .readdirSync(imgsDirAbs, { withFileTypes: true })
      .filter(entry => entry.isFile())
      .map(entry => entry.name)
      .sort((a, b) =>
        new Intl.Collator("en", { numeric: true, sensitivity: "base" }).compare(
          a,
          b
        )
      );
    if (storySlideCount === 0) {
      const baseNameSet = new Set<string>();
      files.forEach(file => {
        if (/\.(avif|bmp|gif|ico|jpe?g|png|svg|tiff?|webp|heic|heif|mp4|webm|ogg|mov|avi|mkv|m4v)$/i.test(file)) {
          baseNameSet.add(file.replace(/\.[^.]+$/, "").toLowerCase());
        }
      });
      storySlideCount = baseNameSet.size;
    }
    const firstVisual = files.find(file =>
      /\.(avif|bmp|gif|ico|jpe?g|png|svg|tiff?|webp|heic|heif)$/i.test(file)
    );
    if (firstVisual) {
      coverRawPath = `${storyDirRelative}/imgs/${firstVisual}`;
    }
  }
}

if (coverRawPath) {
  if (coverRawPath.startsWith("story/")) {
    coverSrc =
      resolveStoryImageAssetUrl(coverRawPath) || `/${coverRawPath}`;
  } else if (/\.(heic|heif)$/i.test(coverRawPath)) {
    coverSrc = getCoverPath(coverRawPath);
  } else {
    const optimized = await optimizeImage(coverRawPath, { thumbnailSize: 480 });
    coverSrc = optimized.thumbnail;
  }
}
---

<li class="my-6">
  <a
    href={getStoryPath(id, filePath)}
    class="group block rounded-xl border border-border/60 bg-card/40 p-4 no-underline transition-all hover:-translate-y-0.5 hover:border-accent/45"
  >
    <div class="flex flex-col gap-4 md:flex-row">
      {
        coverSrc && (
          <div class="h-64 w-full overflow-hidden rounded-lg md:h-48 md:w-36 md:flex-shrink-0">
            <img
              src={coverSrc}
              alt={storyTitle}
              class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-[1.03]"
              loading="lazy"
              decoding="async"
            />
          </div>
        )
      }
      <div class="min-w-0">
        <h2 class="text-accent text-xl font-semibold leading-tight">{storyTitle}</h2>
        <Datetime {pubDatetime} {modDatetime} timezone={SITE.timezone} />
        {
          description?.trim() && (
            <p class="mt-2 text-sm text-foreground/80">{description}</p>
          )
        }
        <p class="mt-2 text-xs text-foreground/60">{storySlideCount} slides</p>
      </div>
    </div>
  </a>
</li>
