---
import { UI } from "@/i18n/ui";

// Remove current url path and remove trailing slash if exists
let currentUrlPath = Astro.url.pathname.replace(/\/+$/, "");

// Remove .html extension if present
currentUrlPath = currentUrlPath.replace(/\.html$/, "");

// Get url array from path
// eg: /tags/tailwindcss => ['tags', 'tailwindcss']
const breadcrumbList = currentUrlPath.split("/").slice(1);

// if breadcrumb is Home > Posts > 1 <etc>
// replace Posts with Posts (page number)
if (breadcrumbList[0] === "tags") {
  breadcrumbList.splice(0, 1);
  breadcrumbList.unshift("blog");
}

// switch (breadcrumbList[0]) {
//   case "tags":
//     break;
//   default:
//     break;
// }

// if breadcrumb is Home > Tags > [tag] > [page] <etc>
// replace [tag] > [page] with [tag] (page number)
if (breadcrumbList[0] === "blog" && !isNaN(Number(breadcrumbList[2]))) {
  const pageNumber = Number(breadcrumbList[2]);
  breadcrumbList.splice(
    1,
    3,
    UI.breadcrumb.tagPage(breadcrumbList[1], pageNumber)
  );
} else if (breadcrumbList[0] === "blog" && !isNaN(Number(breadcrumbList[1]))) {
  const pageNumber = Number(breadcrumbList[1]);
  breadcrumbList.splice(
    0,
    2,
    UI.breadcrumb.postsPage(pageNumber)
  );
} else if (
  breadcrumbList[0] === "story" &&
  !isNaN(Number(breadcrumbList[1]))
) {
  const pageNumber = Number(breadcrumbList[1]);
  breadcrumbList.splice(0, 2, UI.breadcrumb.storyPage(pageNumber));
}
---

<nav class="mx-auto mt-8 mb-1 w-full max-w-app px-4" aria-label="breadcrumb">
  <ul
    class="font-light [&>li]:inline [&>li:not(:last-child)>a]:hover:opacity-100"
  >
    <li>
      <a href="/" class="opacity-80">{UI.breadcrumb.home}</a>
      <span aria-hidden="true" class="opacity-80">&raquo;</span>
    </li>
    {
      breadcrumbList.map((breadcrumb, index) =>
        index + 1 === breadcrumbList.length ? (
          <li>
            <span
              class:list={["capitalize opacity-75", { lowercase: index > 0 }]}
              aria-current="page"
            >
              {/* make the last part lowercase in Home > Tags > some-tag */}
              {/* {decodeURIComponent(breadcrumb)} */}
              {breadcrumb === "blog"
                ? UI.breadcrumb.blog
                : breadcrumb === "diary"
                  ? UI.breadcrumb.diary
                  : breadcrumb === "archives"
                    ? UI.breadcrumb.archives
                    : breadcrumb === "about"
                      ? UI.breadcrumb.about
                      : breadcrumb === "search"
                        ? UI.breadcrumb.search
                        : breadcrumb === "links"
                          ? UI.breadcrumb.links
                        : breadcrumb === "story"
                          ? UI.breadcrumb.stories
                        : decodeURIComponent(breadcrumb)}
            </span>
          </li>
        ) : (
          <li>
            <a href={`/${breadcrumb}/`} class="capitalize opacity-70">
              {breadcrumb === "blog"
                ? UI.breadcrumb.blog
                : breadcrumb === "diary"
                  ? UI.breadcrumb.diary
                  : breadcrumb === "archives"
                    ? UI.breadcrumb.archives
                    : breadcrumb === "about"
                      ? UI.breadcrumb.about
                      : breadcrumb === "search"
                        ? UI.breadcrumb.search
                        : breadcrumb === "links"
                          ? UI.breadcrumb.links
                        : breadcrumb === "story"
                          ? UI.breadcrumb.stories
                        : decodeURIComponent(breadcrumb)}
            </a>
            <span aria-hidden="true">&raquo;</span>
          </li>
        )
      )
    }
  </ul>
</nav>
