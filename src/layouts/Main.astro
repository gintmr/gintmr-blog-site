---
import Breadcrumb from "@/components/Breadcrumb.astro";
interface StringTitleProp {
  pageTitle: string;
  pageDesc?: string;
  wide?: boolean;
}

interface ArrayTitleProp {
  pageTitle: [string, string];
  titleTransition: string;
  pageDesc?: string;
  wide?: boolean;
}

export type Props = StringTitleProp | ArrayTitleProp;

const { props } = Astro;
const mainWidthClass = props.wide ? "max-w-[118rem]" : "max-w-app";
---

<Breadcrumb />
<main id="main-content" class:list={["mx-auto mt-4 w-full px-4 pb-4", mainWidthClass]}>
  {
    "titleTransition" in props ? (
      <h1 class="text-2xl font-semibold sm:text-3xl">
        {props.pageTitle[0]}
        <span transition:name={props.titleTransition}>
          {props.pageTitle[1]}
        </span>
      </h1>
    ) : (
      <h1 class="text-2xl font-semibold sm:text-3xl">{props.pageTitle}</h1>
    )
  }
  <p class="mt-2 mb-6 italic">{props.pageDesc}</p>
  <slot />
</main>
