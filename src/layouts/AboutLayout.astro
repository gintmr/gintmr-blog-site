---
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
// import Breadcrumb from "@/components/Breadcrumb.astro";
import Layout from "./Layout.astro";
import { SITE } from "@/config";

export interface Props {
  frontmatter: {
    title: string;
    description?: string;
  };
}

const { frontmatter } = Astro.props;
---

<Layout title={`${frontmatter.title} | ${SITE.title}`}>
  <Header />
  <!-- <Breadcrumb /> -->
  <main id="main-content" class="mx-auto mt-4 w-full max-w-app px-4 pb-16">
    <section class="subtle-page-note mb-8">
      <div class="subtle-page-note__label">Profile</div>
      <h1 class="mt-2 text-2xl font-semibold sm:text-3xl">{frontmatter.title}</h1>
      {
        frontmatter.description && (
          <p class="mt-3 max-w-2xl text-sm leading-7 text-foreground/72">
            {frontmatter.description}
          </p>
        )
      }
    </section>

    <section id="about" class="app-prose about-prose prose-img:border-0">
      <slot />
    </section>
  </main>
  <Footer />
</Layout>
