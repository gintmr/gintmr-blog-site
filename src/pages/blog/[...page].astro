---
import type { GetStaticPaths } from "astro";
import { getCollection } from "astro:content";
import Main from "@/layouts/Main.astro";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Card from "@/components/Card.astro";
import Pagination from "@/components/Pagination.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import { SITE } from "@/config";
import { UI, UI_LOCALE } from "@/i18n/ui";

// tag
import Tag from "@/components/Tag.astro";
import getUniqueTags from "@/utils/getUniqueTags";

const posts = await getCollection("blog", ({ data }) => !data.draft);
const tags = getUniqueTags(posts);
const browseLabel =
  UI_LOCALE === "zh-CN" ? "按主题浏览" : "Browse by topic";
const pageDesc =
  UI_LOCALE === "zh-CN"
    ? "长文、旅行、工具和一些留下来的念头。"
    : "Long-form notes, travel logs, tools, and whatever stayed with me.";

export const getStaticPaths = (async ({ paginate }) => {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  return paginate(getSortedPosts(posts), { pageSize: SITE.postPerPage });
}) satisfies GetStaticPaths;

const { page } = Astro.props;
---

<Layout title={`${UI.pages.blogTitle} | ${SITE.title}`}>
  <Header />
  <Main pageTitle={UI.pages.allPosts} pageDesc={pageDesc}>
    <section class="subtle-page-note">
      <div class="subtle-page-note__label">{browseLabel}</div>
      <ul class="tag-rail mt-3">
        {tags.map(({ tag, tagName }) => <Tag {tag} {tagName} size="lg" />)}
      </ul>
    </section>

    <ul class="mt-8 space-y-1">
      {page.data.map(data => <Card {...data} />)}
    </ul>
  </Main>

  <Pagination {page} />

  <Footer noMarginTop={page.lastPage > 1} />
</Layout>
