---
import Main from "@/layouts/Main.astro";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import VisitorsInfoPanel from "@/components/VisitorsInfoPanel";
import { SITE } from "@/config";
import { UI } from "@/i18n/ui";
---

<Layout title={`${UI.pages.visitorsInfoTitle} | ${SITE.title}`}>
  <Header />
  <Main pageTitle={UI.pages.visitorsInfoTitle} pageDesc={UI.pages.visitorsInfoDesc} wide={true}>
    <div class="mx-[calc(50%-50vw)] w-screen px-4 sm:px-6 xl:px-8">
      <VisitorsInfoPanel client:load />
    </div>
  </Main>
  <Footer />
</Layout>
