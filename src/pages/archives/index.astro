---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Datetime from "@/components/Datetime.astro";
import { getPath } from "@/utils/getPath";
import { getStoryPath, getStoryTitle } from "@/utils/getStoryPath";
import { optimizeImage } from "@/utils/optimizeImages";
import { isDatePubDatetime, isTopPubDatetime } from "@/utils/pubDatetime";
import { SITE } from "@/config";
import { MONTHS, UI } from "@/i18n/ui";

if (!SITE.showArchives) {
  return Astro.redirect("/404");
}

type ArchiveKind = "blog" | "story";

interface ArchiveItem {
  kind: ArchiveKind;
  title: string;
  description: string;
  pubDatetime: Date | "top";
  modDatetime?: Date | null;
  timezone?: string;
  url: string;
  imageSrc?: string;
}

type TopArchiveItem = ArchiveItem & { pubDatetime: "top" };
type TimelineArchiveItem = ArchiveItem & { pubDatetime: Date };

const blogPosts = await getCollection("blog", ({ data }) => !data.draft);
const storyPosts = await getCollection("story", ({ data }) => !data.draft);

const collator = new Intl.Collator(["en", "zh-Hans-CN-u-co-pinyin"], {
  sensitivity: "base",
  numeric: true,
});

const blogItems: ArchiveItem[] = await Promise.all(
  blogPosts.map(async post => {
    let imageSrc: string | undefined;
    if (typeof post.data.ogImage === "string" && post.data.ogImage.trim()) {
      const optimized = await optimizeImage(post.data.ogImage, {
        thumbnailSize: 360,
      });
      imageSrc = optimized.thumbnail;
    } else if (
      post.data.ogImage &&
      typeof post.data.ogImage === "object" &&
      "src" in post.data.ogImage &&
      typeof post.data.ogImage.src === "string"
    ) {
      imageSrc = post.data.ogImage.src;
    }

    return {
      kind: "blog" as const,
      title: post.data.title,
      description: post.data.description,
      pubDatetime: post.data.pubDatetime,
      modDatetime: post.data.modDatetime,
      timezone: post.data.timezone,
      url: getPath(post.id, post.filePath),
      imageSrc,
    };
  })
);

const storyItems: ArchiveItem[] = storyPosts.map(story => ({
  kind: "story" as const,
  title: getStoryTitle(story.data.title, story.id, story.filePath),
  description: story.data.description ?? "",
  pubDatetime: story.data.pubDatetime,
  modDatetime: story.data.modDatetime,
  url: getStoryPath(story.id, story.filePath),
}));

const mergedArchiveItems: ArchiveItem[] = [...blogItems, ...storyItems];

const isTopArchiveItem = (item: ArchiveItem): item is TopArchiveItem =>
  isTopPubDatetime(item.pubDatetime);

const isTimelineArchiveItem = (
  item: ArchiveItem
): item is TimelineArchiveItem => isDatePubDatetime(item.pubDatetime);

const topArchiveItems = mergedArchiveItems
  .filter(isTopArchiveItem)
  .sort((a, b) => collator.compare(a.title, b.title));

const timelineArchiveItems = mergedArchiveItems
  .filter(isTimelineArchiveItem)
  .sort(
    (a, b) =>
      Math.floor(a.pubDatetime.getTime() / 1000) -
      Math.floor(b.pubDatetime.getTime() / 1000)
  )
  .reverse();

const groupedByYearMonth = timelineArchiveItems.reduce(
  (acc, item) => {
    const year = item.pubDatetime.getFullYear();
    const month = item.pubDatetime.getMonth() + 1;

    if (!acc[year]) acc[year] = {};
    if (!acc[year][month]) acc[year][month] = [];
    acc[year][month].push(item);

    return acc;
  },
  {} as Record<number, Record<number, TimelineArchiveItem[]>>
);

const sourceLabel = {
  blog: UI.nav.blog,
  story: UI.nav.stories,
} satisfies Record<ArchiveKind, string>;
---

<Layout title={`${UI.pages.archivesTitle} | ${SITE.title}`}>
  <Header />

  <main id="main-content" class="archive-shell mx-auto mt-4 w-full max-w-[90rem] px-4 pb-12">
    <Breadcrumb />

    <section class="archive-hero">
      <div class="archive-hero__intro">
        <p class="archive-hero__label">Timebound Catalogue</p>
        <h1 class="archive-hero__title">{UI.pages.archivesTitle}</h1>
        <p class="archive-hero__desc">
          Every long-form entry and remembered reel, arranged as one continuous life-log rather than separate silos.
        </p>
      </div>

      <div class="archive-hero__meta">
        <div class="archive-hero__meta-card">
          <span class="archive-hero__meta-value">{mergedArchiveItems.length}</span>
          <span class="archive-hero__meta-label">Total archived entries</span>
        </div>
        <div class="archive-hero__meta-card">
          <span class="archive-hero__meta-value">{topArchiveItems.length}</span>
          <span class="archive-hero__meta-label">Pinned records</span>
        </div>
      </div>
    </section>

    {
      topArchiveItems.length > 0 && (
        <section id="top" class="archive-cluster archive-cluster--top">
          <div class="archive-cluster__head">
            <div>
              <p class="archive-cluster__label">{UI.common.top}</p>
              <h2 class="archive-cluster__title">Pinned Atlas</h2>
            </div>
            <p class="archive-cluster__hint">
              Entries without a date placement, held above the timeline as permanent markers.
            </p>
          </div>

          <div class="archive-grid archive-grid--top">
            {topArchiveItems.map(item => (
              <article class="archive-entry archive-entry--top">
                {
                  item.kind === "blog" && item.imageSrc ? (
                    <a href={item.url} class="archive-entry__thumb-link" aria-label={item.title}>
                      <img
                        src={item.imageSrc}
                        alt={item.title}
                        width={720}
                        height={480}
                        class="archive-entry__thumb"
                        loading="lazy"
                        decoding="async"
                      />
                    </a>
                  ) : (
                    <div class="archive-entry__story-badge">Story</div>
                  )
                }

                <div class="archive-entry__content">
                  <div class="archive-entry__meta-row">
                    <span class="archive-entry__pill archive-entry__pill--top">{UI.common.top}</span>
                    <span class="archive-entry__pill">{sourceLabel[item.kind]}</span>
                  </div>
                  <h3 class="archive-entry__title">
                    <a href={item.url}>{item.title}</a>
                  </h3>
                  {
                    item.description && (
                      <p class="archive-entry__desc">{item.description}</p>
                    )
                  }
                </div>
              </article>
            ))}
          </div>
        </section>
      )
    }

    <section class="archive-timeline">
      {
        Object.entries(groupedByYearMonth)
          .sort(([yearA], [yearB]) => Number(yearB) - Number(yearA))
          .map(([year, monthMap]) => {
            const yearItems = Object.values(monthMap).flat();

            return (
              <section class="archive-year-block">
                <div class="archive-year-block__head">
                  <div>
                    <p class="archive-year-block__eyebrow">Year</p>
                    <h2 class="archive-year-block__title">{year}</h2>
                  </div>
                  <span class="archive-year-block__count">{yearItems.length} entries</span>
                </div>

                <div class="archive-year-block__body">
                  {Object.entries(monthMap)
                    .sort(([monthA], [monthB]) => Number(monthB) - Number(monthA))
                    .map(([month, items]) => (
                      <section class="archive-month-block">
                        <div class="archive-month-block__label">{MONTHS[Number(month) - 1]}</div>

                        <div class="archive-month-block__entries">
                          {items.map(item => (
                            <article class:list={["archive-entry", item.kind === "story" && "archive-entry--story"]}>
                              {
                                item.kind === "blog" && item.imageSrc ? (
                                  <a
                                    href={item.url}
                                    class="archive-entry__thumb-link"
                                    aria-label={item.title}
                                  >
                                    <img
                                      src={item.imageSrc}
                                      alt={item.title}
                                      width={720}
                                      height={480}
                                      class="archive-entry__thumb"
                                      loading="lazy"
                                      decoding="async"
                                    />
                                  </a>
                                ) : (
                                  <div class="archive-entry__story-badge">Story</div>
                                )
                              }

                              <div class="archive-entry__content">
                                <div class="archive-entry__meta-row">
                                  <span class="archive-entry__pill">{sourceLabel[item.kind]}</span>
                                </div>

                                <h3 class="archive-entry__title">
                                  <a href={item.url}>{item.title}</a>
                                </h3>

                                <div class="archive-entry__datetime">
                                  <Datetime
                                    pubDatetime={item.pubDatetime}
                                    modDatetime={item.modDatetime}
                                    timezone={item.timezone}
                                  />
                                </div>

                                {
                                  item.description && (
                                    <p class="archive-entry__desc">{item.description}</p>
                                  )
                                }
                              </div>
                            </article>
                          ))}
                        </div>
                      </section>
                    ))}
                </div>
              </section>
            );
          })
      }
    </section>
  </main>

  <Footer />
</Layout>
