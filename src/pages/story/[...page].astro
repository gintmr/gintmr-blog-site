---
import type { GetStaticPaths } from "astro";
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Pagination from "@/components/Pagination.astro";
import StoryCard from "@/components/StoryCard.astro";
import getSortedStories from "@/utils/getSortedStories";
import { SITE } from "@/config";
import { UI } from "@/i18n/ui";

export const getStaticPaths = (async ({ paginate }) => {
  const stories = await getCollection("story", ({ data }) => !data.draft);
  return paginate(getSortedStories(stories), { pageSize: 18 });
}) satisfies GetStaticPaths;

const { page } = Astro.props;
---

<Layout title={`${UI.pages.storiesTitle} | ${SITE.title}`}>
  <Header />
  <main id="main-content" class="mx-auto mt-4 w-full max-w-[88rem] px-4 pb-6">
    <h1 class="text-3xl font-semibold">{UI.pages.storiesTitle}</h1>
    <p class="mt-2 mb-6 text-sm italic text-foreground/72">{UI.pages.storiesDesc}</p>
    <ul class="story-wall grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
      {page.data.map(data => <StoryCard {...data} />)}
    </ul>
  </main>
  <Pagination {page} />
  <Footer noMarginTop={page.lastPage > 1} />
</Layout>

<script is:inline>
  (() => {
    let observer = null;

    const loadVideoMeta = video => {
      if (!(video instanceof HTMLVideoElement)) return;
      if (video.dataset.storyMetaLoaded === "true") return;

      video.dataset.storyMetaLoaded = "true";
      video.preload = "metadata";
      if (video.readyState < 1) {
        try {
          video.load();
        } catch {
          // ignore
        }
      }
      if (observer) observer.unobserve(video);
    };

    const initStoryWallVideoLazyLoad = () => {
      if (observer) {
        observer.disconnect();
        observer = null;
      }

      const videos = Array.from(
        document.querySelectorAll("video[data-story-card-video]")
      ).filter(node => node instanceof HTMLVideoElement);
      if (videos.length === 0) return;

      const eagerCount = window.matchMedia("(max-width: 640px)").matches ? 2 : 4;
      videos.slice(0, eagerCount).forEach(loadVideoMeta);

      if (!("IntersectionObserver" in window)) {
        videos.slice(eagerCount).forEach(loadVideoMeta);
        return;
      }

      observer = new IntersectionObserver(
        entries => {
          entries.forEach(entry => {
            if (!entry.isIntersecting) return;
            loadVideoMeta(entry.target);
          });
        },
        {
          root: null,
          rootMargin: "260px 0px",
          threshold: 0.01,
        }
      );

      videos.slice(eagerCount).forEach(video => observer.observe(video));
    };

    document.addEventListener("astro:page-load", initStoryWallVideoLazyLoad);
    document.addEventListener("astro:before-preparation", () => {
      if (observer) {
        observer.disconnect();
        observer = null;
      }
    });

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", initStoryWallVideoLazyLoad, {
        once: true,
      });
    } else {
      initStoryWallVideoLazyLoad();
    }
  })();
</script>
