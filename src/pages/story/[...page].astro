---
import type { GetStaticPaths } from "astro";
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Pagination from "@/components/Pagination.astro";
import StoryCard from "@/components/StoryCard.astro";
import getSortedStories from "@/utils/getSortedStories";
import { SITE } from "@/config";
import { UI } from "@/i18n/ui";

export const getStaticPaths = (async ({ paginate }) => {
  const stories = await getCollection("story", ({ data }) => !data.draft);
  return paginate(getSortedStories(stories), { pageSize: 18 });
}) satisfies GetStaticPaths;

const { page } = Astro.props;
---

<Layout title={`${UI.pages.storiesTitle} | ${SITE.title}`}>
  <Header />
  <main id="main-content" class="mx-auto mt-4 w-full max-w-[88rem] px-4 pb-6">
    <h1 class="text-3xl font-semibold">{UI.pages.storiesTitle}</h1>
    <p class="mt-2 mb-6 text-sm italic text-foreground/72">{UI.pages.storiesDesc}</p>
    <ul class="story-wall columns-2 gap-4 md:columns-3 xl:columns-4">
      {page.data.map(data => <StoryCard {...data} />)}
    </ul>
  </main>
  <Pagination {page} />
  <Footer noMarginTop={page.lastPage > 1} />
</Layout>
