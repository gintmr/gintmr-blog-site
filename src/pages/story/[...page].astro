---
import type { GetStaticPaths } from "astro";
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Pagination from "@/components/Pagination.astro";
import StoryCard from "@/components/StoryCard.astro";
import getSortedStories from "@/utils/getSortedStories";
import { getStoryPath, getStoryTitle } from "@/utils/getStoryPath";
import { resolveStoryVideoUrlByEntry } from "@/utils/storyVideo";
import { SITE } from "@/config";
import { UI } from "@/i18n/ui";

export const getStaticPaths = (async ({ paginate }) => {
  const stories = await getCollection("story", ({ data }) => !data.draft);
  return paginate(getSortedStories(stories), { pageSize: 18 });
}) satisfies GetStaticPaths;

const { page } = Astro.props;
const [leadStory, ...gridStories] = page.data;
const leadStoryTitle = leadStory
  ? getStoryTitle(leadStory.data.title, leadStory.id, leadStory.filePath)
  : "";
const leadStoryPath = leadStory
  ? getStoryPath(leadStory.id, leadStory.filePath)
  : "#";
const leadStoryVideoSrc = leadStory
  ? resolveStoryVideoUrlByEntry(leadStory.id, leadStory.filePath)
  : undefined;
const timelineYears = new Set(
  page.data
    .map(entry => entry.data.pubDatetime)
    .filter(value => value instanceof Date)
    .map(value => value.getFullYear())
).size;
---

<Layout title={`${UI.pages.storiesTitle} | ${SITE.title}`}>
  <Header />
  <main id="main-content" class="story-index-shell mx-auto mt-4 w-full max-w-[92rem] px-4 pb-10">
    <Breadcrumb />

    <section class="story-index-hero">
      <div class="story-index-hero__intro">
        <p class="story-index-hero__label">Album Memories</p>
        <h1 class="story-index-hero__title">{UI.pages.storiesTitle}</h1>
        <p class="story-index-hero__desc">
          A shelf of vertical memories, backed up as moving fragments instead of disappearing feeds.
        </p>
      </div>

      <div class="story-index-hero__meta">
        <div class="story-index-hero__meta-card">
          <span class="story-index-hero__meta-value">{page.data.length}</span>
          <span class="story-index-hero__meta-label">
            {page.currentPage > 1 ? `Reels on page ${page.currentPage}` : "Visible reels"}
          </span>
        </div>
        <div class="story-index-hero__meta-card">
          <span class="story-index-hero__meta-value">{timelineYears || 1}</span>
          <span class="story-index-hero__meta-label">Years in this slice</span>
        </div>
      </div>
    </section>

    {
      leadStory && (
        <section class="story-showcase">
          <a href={leadStoryPath} class="story-showcase__lead group">
            <div class="story-showcase__media">
              {
                leadStoryVideoSrc ? (
                  <video
                    src={`${leadStoryVideoSrc}#t=0.1`}
                    preload="none"
                    muted
                    playsinline
                    data-story-card-video
                    class="story-showcase__video"
                  />
                ) : (
                  <div class="story-showcase__fallback">Video not found</div>
                )
              }
              <span class="story-showcase__play">Play memory</span>
            </div>
            <div class="story-showcase__copy">
              <p class="story-showcase__eyebrow">Lead Memory</p>
              <h2 class="story-showcase__title">{leadStoryTitle}</h2>
              {
                leadStory.data.description?.trim() && (
                  <p class="story-showcase__desc">{leadStory.data.description}</p>
                )
              }
              <span class="story-showcase__cta">Open story</span>
            </div>
          </a>

          {
            gridStories.length > 0 && (
              <ul class="story-wall story-wall--gallery">
                {gridStories.map(data => <StoryCard {...data} />)}
              </ul>
            )
          }
        </section>
      )
    }
  </main>
  <Pagination {page} />
  <Footer noMarginTop={page.lastPage > 1} />
</Layout>

<script is:inline>
  (() => {
    let observer = null;

    const loadVideoMeta = video => {
      if (!(video instanceof HTMLVideoElement)) return;
      if (video.dataset.storyMetaLoaded === "true") return;

      video.dataset.storyMetaLoaded = "true";
      video.preload = "metadata";
      if (video.readyState < 1) {
        try {
          video.load();
        } catch {
          // ignore
        }
      }
      if (observer) observer.unobserve(video);
    };

    const initStoryWallVideoLazyLoad = () => {
      if (observer) {
        observer.disconnect();
        observer = null;
      }

      const videos = Array.from(
        document.querySelectorAll("video[data-story-card-video]")
      ).filter(node => node instanceof HTMLVideoElement);
      if (videos.length === 0) return;

      const eagerCount = window.matchMedia("(max-width: 640px)").matches ? 2 : 4;
      videos.slice(0, eagerCount).forEach(loadVideoMeta);

      if (!("IntersectionObserver" in window)) {
        videos.slice(eagerCount).forEach(loadVideoMeta);
        return;
      }

      observer = new IntersectionObserver(
        entries => {
          entries.forEach(entry => {
            if (!entry.isIntersecting) return;
            loadVideoMeta(entry.target);
          });
        },
        {
          root: null,
          rootMargin: "260px 0px",
          threshold: 0.01,
        }
      );

      videos.slice(eagerCount).forEach(video => observer.observe(video));
    };

    document.addEventListener("astro:page-load", initStoryWallVideoLazyLoad);
    document.addEventListener("astro:before-preparation", () => {
      if (observer) {
        observer.disconnect();
        observer = null;
      }
    });

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", initStoryWallVideoLazyLoad, {
        once: true,
      });
    } else {
      initStoryWallVideoLazyLoad();
    }
  })();
</script>
