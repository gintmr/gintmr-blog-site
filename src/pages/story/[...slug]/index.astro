---
import { getCollection, render, type CollectionEntry } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import BackButton from "@/components/BackButton.astro";
import BackToTopButton from "@/components/BackToTopButton.astro";
import Datetime from "@/components/Datetime.astro";
import IconChevronLeft from "@/assets/icons/IconChevronLeft.svg";
import IconChevronRight from "@/assets/icons/IconChevronRight.svg";
import { SITE } from "@/config";
import { UI } from "@/i18n/ui";
import getSortedStories from "@/utils/getSortedStories";
import { getStoryPath, getStoryTitle } from "@/utils/getStoryPath";
import { resolveStoryVideoUrlByEntry } from "@/utils/storyVideo";
import { isDatePubDatetime } from "@/utils/pubDatetime";

export interface Props {
  story: CollectionEntry<"story">;
  stories: CollectionEntry<"story">[];
  storyVideoSrc?: string;
}

export async function getStaticPaths() {
  const stories = await getCollection("story", ({ data }) => !data.draft);
  const timelineStories = getSortedStories(stories);

  return stories.map(story => ({
    params: {
      slug: getStoryPath(story.id, story.filePath, false).replace(/^\/+/, ""),
    },
    props: {
      story,
      stories: timelineStories,
      storyVideoSrc: resolveStoryVideoUrlByEntry(story.id, story.filePath),
    },
  }));
}

const { story, stories, storyVideoSrc } = Astro.props;
const renderedStory = await render(story);
const Content = renderedStory.Content;

const { title, description, author, pubDatetime, modDatetime } = story.data;
const storyTitle = getStoryTitle(title, story.id, story.filePath);
const storyDescription = description?.trim() || "";
const publishDatetime = isDatePubDatetime(pubDatetime) ? pubDatetime : undefined;
const modifiedDatetime = isDatePubDatetime(modDatetime) ? modDatetime : undefined;

const currentStoryIndex = stories.findIndex(item => item.id === story.id);
const prevStory = currentStoryIndex > 0 ? stories[currentStoryIndex - 1] : null;
const nextStory =
  currentStoryIndex >= 0 && currentStoryIndex < stories.length - 1
    ? stories[currentStoryIndex + 1]
    : null;
---

<Layout
  title={`${storyTitle} | ${SITE.title}`}
  description={storyDescription}
  author={author}
  pubDatetime={publishDatetime}
  modDatetime={modifiedDatetime}
  scrollSmooth={true}
>
  <Header />
  <BackButton />

  <main id="main-content" class="story-detail-shell mx-auto mt-4 w-full max-w-[94rem] px-4 pb-12">
    <section class="story-memory-detail">
      <div class="story-memory-stage-shell">
        <div class="story-memory-stage" data-story-video-stage>
          {
            storyVideoSrc ? (
              <video
                data-story-main-video
                class="story-memory-video"
                src={storyVideoSrc}
                controls
                preload="metadata"
                playsinline
              />
            ) : (
              <div class="story-memory-video-empty">
                No video file found. Please ensure the `.md` and `.mov/.mp4` filenames match.
              </div>
            )
          }
        </div>

        <div class="story-memory-nav">
          {
            prevStory ? (
              <a
                href={getStoryPath(prevStory.id, prevStory.filePath)}
                class="story-memory-nav__item"
              >
                <span class="story-memory-nav__label">{UI.post.previous}</span>
                <span class="story-memory-nav__title">
                  <IconChevronLeft class="story-memory-nav__icon" />
                  {getStoryTitle(prevStory.data.title, prevStory.id, prevStory.filePath)}
                </span>
              </a>
            ) : (
              <div class="story-memory-nav__item story-memory-nav__item--empty"></div>
            )
          }
          {
            nextStory ? (
              <a
                href={getStoryPath(nextStory.id, nextStory.filePath)}
                class="story-memory-nav__item story-memory-nav__item--next"
              >
                <span class="story-memory-nav__label">{UI.post.next}</span>
                <span class="story-memory-nav__title">
                  {getStoryTitle(nextStory.data.title, nextStory.id, nextStory.filePath)}
                  <IconChevronRight class="story-memory-nav__icon" />
                </span>
              </a>
            ) : (
              <div class="story-memory-nav__item story-memory-nav__item--empty"></div>
            )
          }
        </div>
      </div>

      <aside class="story-memory-panel">
        <p class="story-memory-panel__eyebrow">Vertical Memory</p>
        <h1 class="story-memory-panel__title">{storyTitle}</h1>
        {
          publishDatetime && (
            <div class="story-memory-panel__meta">
              <Datetime
                pubDatetime={publishDatetime}
                modDatetime={modifiedDatetime}
                timezone={SITE.timezone}
              />
            </div>
          )
        }
        {
          storyDescription && (
            <p class="story-memory-panel__desc">{storyDescription}</p>
          )
        }

        <article class="story-memory-prose app-prose text-sm">
          <Content />
        </article>
      </aside>
    </section>

    <hr class="my-8 border-dashed" />
    <BackToTopButton />
  </main>

  <Footer />
</Layout>
