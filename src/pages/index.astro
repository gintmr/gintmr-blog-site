---
import Footer from "@/components/Footer.astro";
import Header from "@/components/Header.astro";
import BackToTopButton from "@/components/BackToTopButton.astro";
import { SITE } from "@/config";
import Layout from "@/layouts/Layout.astro";
import { getCollection } from "astro:content";
import { parseDiaryIdentifier } from "@/utils/diaryIdentifier";
import { parseEntry } from "@/utils/parseEntry";
import DiaryTimeline from "@/components/DiaryTimeline.tsx";
import QuickJumpNav from "@/components/QuickJumpNav.astro";
import QuoteSpotlight from "@/components/QuoteSpotlight.astro";
import { UI, UI_LOCALE } from "@/i18n/ui";

const diaryEntries = await getCollection("diary");

// 过滤掉草稿状态的条目
const publishedEntries = diaryEntries.filter(entry => !entry.data.draft);

// 按文件名（日期）排序，最新的在前
// 同时确保同一天内的时间块也按时间倒序排列
const sortedEntries = publishedEntries.sort((a, b) => {
  const metaA = parseDiaryIdentifier(a.id);
  const metaB = parseDiaryIdentifier(b.id);
  return metaB.sortKey.localeCompare(metaA.sortKey);
});

// 分页设置
const ITEMS_PER_PAGE = 5;
const initialEntries = sortedEntries.slice(0, ITEMS_PER_PAGE);

// 解析初始数据
const initialParsedEntries = await Promise.all(initialEntries.map(parseEntry));

// 为了性能考虑，只解析初始数据，其他数据通过API端点按需加载
// 创建分页数据结构
const totalPages = Math.ceil(sortedEntries.length / ITEMS_PER_PAGE);
const paginationInfo = {
  currentPage: 1,
  totalPages,
  hasMore: totalPages > 1,
  itemsPerPage: ITEMS_PER_PAGE,
};

function getFirstMeaningfulText(blocks: typeof initialParsedEntries[number]["timeBlocks"]) {
  for (const block of blocks) {
    if (block.text) {
      const plain = block.text
        .replace(/<[^>]+>/g, " ")
        .replace(/\s+/g, " ")
        .trim();
      if (plain) return plain;
    }
  }
  return "";
}

function getLeadImages(blocks: typeof initialParsedEntries[number]["timeBlocks"]) {
  const collected: Array<{ src: string; alt: string; title?: string }> = [];

  for (const block of blocks) {
    if (block.imageGroups?.length) {
      for (const group of block.imageGroups) {
        for (const image of group) {
          if (!image?.src) continue;
          collected.push({
            src: image.src,
            alt: image.alt || image.title || "image",
            title: image.title,
          });
          if (collected.length >= 3) return collected;
        }
      }
    }

    if (block.images?.length) {
      for (const image of block.images) {
        if (!image?.src) continue;
        collected.push({
          src: image.src,
          alt: image.alt || image.title || "image",
          title: image.title,
        });
        if (collected.length >= 3) return collected;
      }
    }
  }

  return collected;
}

const leadEntry = initialParsedEntries[0];
const leadEntryId =
  leadEntry &&
  (leadEntry.isDateRange && leadEntry.dateEnd
    ? `${leadEntry.date}_to_${leadEntry.dateEnd}`
    : leadEntry.date);
const leadPreviewText = leadEntry
  ? getFirstMeaningfulText(leadEntry.timeBlocks).slice(0, 180)
  : "";
const leadPreviewImages = leadEntry ? getLeadImages(leadEntry.timeBlocks) : [];
const leadDispatch = leadEntry
  ? {
      label: UI_LOCALE === "zh-CN" ? "Latest Dispatch" : "Latest Dispatch",
      title: UI_LOCALE === "zh-CN" ? "从最新一页开始" : "Begin with the newest page",
      desc:
        leadPreviewText ||
        (UI_LOCALE === "zh-CN"
          ? "先从最新一篇时间记录开始，再顺着时间线向下走。"
          : "Start from the latest diary entry, then continue down the timeline."),
      date: leadEntry.date,
      location: leadEntry.locationName,
      href: leadEntryId ? `#date-${leadEntryId}` : "#diary-content",
    }
  : null;

const homeLaunch = UI_LOCALE === "zh-CN"
  ? {
      label: "Start Here",
      items: [
        {
          href: "/blog",
          title: "Blog",
          desc: "长文章、图文记录与一些值得认真写下来的内容。",
        },
        {
          href: "/story",
          title: "Story",
          desc: "竖屏短视频相册，适合快速浏览近期记忆。",
        },
        {
          href: "/archives#top",
          title: "Top",
          desc: "查看置顶内容与完整时间归档，快速进入全站索引。",
        },
      ],
    }
  : {
      label: "Start Here",
      items: [
        {
          href: "/blog",
          title: "Blog",
          desc: "Long-form notes, essays, and entries worth slowing down for.",
        },
        {
          href: "/story",
          title: "Story",
          desc: "A short-form wall of vertical memory clips for quick browsing.",
        },
        {
          href: "/archives#top",
          title: "Top",
          desc: "Pinned entries and the full archive, arranged as one timeline.",
        },
      ],
    };
---

<Layout title={`${UI.pages.timelineTitle} | ${SITE.title}`}>
  <Header />

  <main
    id="main-content"
    data-pagefind-ignore
    role="main"
    aria-label={`${UI.pages.timelineTitle} main content`}
  >
    <!-- 跳转到主要内容的链接 -->
    <a
      href="#diary-content"
      class="focus:bg-skin-accent focus:text-skin-inverted sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:rounded focus:px-4 focus:py-2 focus:no-underline"
    >
      Skip to main content
    </a>

    <section
      id="diary"
      class="from-skin-fill via-skin-card to-skin-fill mx-auto min-h-screen max-w-app bg-gradient-to-br px-4 pt-4"
      role="region"
      aria-labelledby="diary-heading"
    >
      <div class="min-h-screen">
        <!-- 页面标题 -->
        <header class="py-0">
          <h1 id="diary-heading" class="sr-only">{UI.pages.timelineTitle}</h1>
          <p class="sr-only">
            Diary entries in reverse chronological order with infinite loading.
          </p>
        </header>

        <!-- 主要内容区域 -->
        <div class="py-8">
          <QuoteSpotlight />

          <section class="subtle-page-note mt-6 mb-8">
            <div class="subtle-page-note__label">Life Log</div>
            <p class="text-sm leading-7 text-foreground/72">
              A reverse-chronological stream of places, fragments, photos, and
              ordinary days worth remembering.
            </p>
          </section>

          {leadDispatch && (
            <section class="home-feature mb-10" aria-label={leadDispatch.label}>
              <a href={leadDispatch.href} class="home-feature__panel group">
                <div class="home-feature__copy">
                  <div class="home-feature__label">{leadDispatch.label}</div>
                  <h2 class="home-feature__title">{leadDispatch.title}</h2>
                  <p class="home-feature__desc">{leadDispatch.desc}</p>

                  <div class="home-feature__meta">
                    <span class="home-feature__chip">{leadDispatch.date}</span>
                    {leadDispatch.location && (
                      <span class="home-feature__chip home-feature__chip--muted">
                        {leadDispatch.location}
                      </span>
                    )}
                  </div>
                </div>

                <div class="home-feature__visual" aria-hidden="true">
                  {leadPreviewImages.length > 0 ? (
                    <div class="home-feature__collage">
                      {leadPreviewImages.map((image, index) => (
                        <figure class={`home-feature__shot home-feature__shot--${index + 1}`}>
                          <img src={image.src} alt={image.alt} loading="lazy" />
                        </figure>
                      ))}
                    </div>
                  ) : (
                    <div class="home-feature__fallback">
                      <span>↘</span>
                    </div>
                  )}
                </div>
              </a>
            </section>
          )}

          <section class="home-launch-grid mt-0 mb-10" aria-label={homeLaunch.label}>
            {homeLaunch.items.map(item => (
              <a href={item.href} class="home-launch-card group">
                <div class="home-launch-card__eyebrow">{homeLaunch.label}</div>
                <h2 class="home-launch-card__title">{item.title}</h2>
                <p class="home-launch-card__desc">{item.desc}</p>
                <span class="home-launch-card__cta" aria-hidden="true">↗</span>
              </a>
            ))}
          </section>

          <div id="diary-description" class="sr-only">
            Entries are shown in reverse chronological order. {ITEMS_PER_PAGE}{" "}
            records per page, {sortedEntries.length} in total.
          </div>
          <div
            id="diary-content"
            role="feed"
            aria-label="Diary timeline"
            aria-describedby="diary-description"
            aria-live="polite"
            aria-busy="false"
          >
            <DiaryTimeline
              client:load
              initialEntries={initialParsedEntries}
              paginationInfo={paginationInfo}
            />
          </div>
          <QuickJumpNav
            mode="diary"
            headingSelector="#diary-content h2[id^='date-']"
            containerSelector="#diary-content"
          />
        </div>

        <BackToTopButton />
      </div>
    </section>
  </main>

  <Footer />
</Layout>
