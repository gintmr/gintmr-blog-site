---
import Footer from "@/components/Footer.astro";
import Header from "@/components/Header.astro";
import BackToTopButton from "@/components/BackToTopButton.astro";
import { SITE } from "@/config";
import Layout from "@/layouts/Layout.astro";
import QuoteSpotlight from "@/components/QuoteSpotlight.astro";
import { getCollection } from "astro:content";
import { parseDiaryIdentifier } from "@/utils/diaryIdentifier";
import { parseEntry } from "@/utils/parseEntry";
import DiaryTimeline from "@/components/DiaryTimeline.tsx";
import QuickJumpNav from "@/components/QuickJumpNav.astro";
import { UI, UI_LOCALE } from "@/i18n/ui";
import getSortedPosts from "@/utils/getSortedPosts";
import getSortedStories from "@/utils/getSortedStories";
import { getPublishTimestamp, isDatePubDatetime } from "@/utils/pubDatetime";
import { optimizeImage } from "@/utils/optimizeImages";
import { getPath } from "@/utils/getPath";
import { getStoryPath, getStoryTitle } from "@/utils/getStoryPath";
import { resolveStoryVideoUrlByEntry } from "@/utils/storyVideo";

const diaryEntries = await getCollection("diary");
const blogEntries = getSortedPosts(await getCollection("blog"));
const storyEntries = getSortedStories(await getCollection("story"));

// 过滤掉草稿状态的条目
const publishedEntries = diaryEntries.filter(entry => !entry.data.draft);

// 按文件名（日期）排序，最新的在前
// 同时确保同一天内的时间块也按时间倒序排列
const sortedEntries = publishedEntries.sort((a, b) => {
  const metaA = parseDiaryIdentifier(a.id);
  const metaB = parseDiaryIdentifier(b.id);
  return metaB.sortKey.localeCompare(metaA.sortKey);
});

// 分页设置
const ITEMS_PER_PAGE = 5;
const initialEntries = sortedEntries.slice(0, ITEMS_PER_PAGE);

// 解析初始数据
const initialParsedEntries = await Promise.all(initialEntries.map(parseEntry));

// 为了性能考虑，只解析初始数据，其他数据通过API端点按需加载
// 创建分页数据结构
const totalPages = Math.ceil(sortedEntries.length / ITEMS_PER_PAGE);
const paginationInfo = {
  currentPage: 1,
  totalPages,
  hasMore: totalPages > 1,
  itemsPerPage: ITEMS_PER_PAGE,
};

function formatDateLabel(value: Date | undefined): string | undefined {
  if (!value) return undefined;

  return new Intl.DateTimeFormat("sv-SE", {
    timeZone: SITE.timezone,
    year: "numeric",
    month: "2-digit",
    day: "2-digit",
  }).format(value);
}

function resolveDisplayDate(
  modDatetime: Date | null | undefined,
  pubDatetime: unknown
): Date | undefined {
  if (isDatePubDatetime(modDatetime)) return modDatetime;
  if (isDatePubDatetime(pubDatetime)) return pubDatetime;
  return undefined;
}

async function resolveBlogLeadImage(entry: (typeof blogEntries)[number] | undefined) {
  if (!entry) return undefined;

  const ogImage = entry.data.ogImage;
  if (typeof ogImage === "string" && ogImage.trim()) {
    const optimized = await optimizeImage(ogImage, { thumbnailSize: 900 });
    return optimized.thumbnail;
  }

  if (
    ogImage &&
    typeof ogImage === "object" &&
    "src" in ogImage &&
    typeof ogImage.src === "string"
  ) {
    return ogImage.src;
  }

  return undefined;
}

const latestBlog = blogEntries[0];
const latestStory = storyEntries[0];
const latestBlogTimestamp = latestBlog
  ? getPublishTimestamp(latestBlog.data.modDatetime ?? latestBlog.data.pubDatetime)
  : null;
const latestStoryTimestamp = latestStory
  ? getPublishTimestamp(latestStory.data.modDatetime ?? latestStory.data.pubDatetime)
  : null;

const leadMode =
  latestStory &&
  latestStoryTimestamp !== null &&
  (latestBlogTimestamp === null || latestStoryTimestamp > latestBlogTimestamp)
    ? "story"
    : latestBlog
      ? "blog"
      : latestStory
        ? "story"
        : null;

const leadStoryTitle =
  latestStory && getStoryTitle(latestStory.data.title, latestStory.id, latestStory.filePath);
const leadStoryVideoSrc =
  latestStory && resolveStoryVideoUrlByEntry(latestStory.id, latestStory.filePath);
const leadBlogImageSrc = await resolveBlogLeadImage(latestBlog);

const leadDispatch =
  leadMode === "story" && latestStory
    ? {
        label: UI_LOCALE === "zh-CN" ? "Spotlight" : "Spotlight",
        kicker: UI_LOCALE === "zh-CN" ? "Latest Story" : "Latest Story",
        title: leadStoryTitle,
        desc:
          latestStory.data.description?.trim() ||
          (UI_LOCALE === "zh-CN"
            ? "最新发布的一期竖屏短篇，适合从这里进入最近的记忆切片。"
            : "The latest short vertical story, a quick way into the newest memory clip."),
        date: formatDateLabel(
          resolveDisplayDate(latestStory.data.modDatetime, latestStory.data.pubDatetime)
        ),
        href: getStoryPath(latestStory.id, latestStory.filePath),
        mediaType: "story" as const,
        mediaSrc: leadStoryVideoSrc,
      }
    : leadMode === "blog" && latestBlog
      ? {
          label: UI_LOCALE === "zh-CN" ? "Spotlight" : "Spotlight",
          kicker: UI_LOCALE === "zh-CN" ? "Latest Blog" : "Latest Blog",
          title: latestBlog.data.title,
        desc:
          latestBlog.data.description?.trim() ||
          (UI_LOCALE === "zh-CN"
            ? "最新发布的一篇长文，从这里开始进入最近一次完整记录。"
            : "The latest long-form entry, a good place to start with the newest full record."),
        date: formatDateLabel(
          resolveDisplayDate(latestBlog.data.modDatetime, latestBlog.data.pubDatetime)
        ),
        href: getPath(latestBlog.id, latestBlog.filePath),
        mediaType: "blog" as const,
        mediaSrc: leadBlogImageSrc,
        }
      : null;
const timelinePrelude = UI_LOCALE === "zh-CN"
  ? {
      label: "Recent Pages",
      desc: "下面开始按时间倒序浏览 diary 时间流。",
    }
  : {
      label: "Recent Pages",
      desc: "The reverse-chronological diary stream begins here.",
    };
---

<Layout title={`${UI.pages.timelineTitle} | ${SITE.title}`}>
  <Header />

  <main
    id="main-content"
    data-pagefind-ignore
    role="main"
    aria-label={`${UI.pages.timelineTitle} main content`}
  >
    <!-- 跳转到主要内容的链接 -->
    <a
      href="#diary-content"
      class="focus:bg-skin-accent focus:text-skin-inverted sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:rounded focus:px-4 focus:py-2 focus:no-underline"
    >
      Skip to main content
    </a>

    <section
      id="diary"
      class="from-skin-fill via-skin-card to-skin-fill mx-auto min-h-screen max-w-app bg-gradient-to-br px-4 pt-4"
      role="region"
      aria-labelledby="diary-heading"
    >
      <div class="min-h-screen">
        <!-- 页面标题 -->
        <header class="py-0">
          <h1 id="diary-heading" class="sr-only">{UI.pages.timelineTitle}</h1>
          <p class="sr-only">
            Diary entries in reverse chronological order with infinite loading.
          </p>
        </header>

        <!-- 主要内容区域 -->
        <div class="py-8">
          <QuoteSpotlight />

          {leadDispatch && (
            <section class="home-feature home-feature--solo mb-8" aria-label={leadDispatch.label}>
              <a href={leadDispatch.href} class="home-feature__panel group">
                <div class="home-feature__copy">
                  <div class="home-feature__label">{leadDispatch.label}</div>
                  <div class="home-feature__kicker">{leadDispatch.kicker}</div>
                  <h2 class="home-feature__title">{leadDispatch.title}</h2>
                  <p class="home-feature__desc">{leadDispatch.desc}</p>

                  <div class="home-feature__meta">
                    {leadDispatch.date && <span class="home-feature__chip">{leadDispatch.date}</span>}
                    <span class="home-feature__chip home-feature__chip--muted">
                      {leadDispatch.mediaType === "story"
                        ? UI_LOCALE === "zh-CN"
                          ? "Story"
                          : "Story"
                        : UI_LOCALE === "zh-CN"
                          ? "Blog"
                          : "Blog"}
                    </span>
                  </div>
                </div>

                <div class="home-feature__visual" aria-hidden="true">
                  {leadDispatch.mediaSrc ? (
                    <div class={`home-feature__media home-feature__media--${leadDispatch.mediaType}`}>
                      {leadDispatch.mediaType === "story" ? (
                        <>
                          <video
                            class="home-feature__video"
                            src={`${leadDispatch.mediaSrc}#t=0.1`}
                            muted
                            playsinline
                            autoplay
                            loop
                            preload="metadata"
                          />
                          <span class="home-feature__play">▶</span>
                        </>
                      ) : (
                        <img
                          class="home-feature__cover"
                          src={leadDispatch.mediaSrc}
                          alt={leadDispatch.title}
                          loading="lazy"
                        />
                      )}
                    </div>
                  ) : (
                    <div class="home-feature__fallback">
                      <span>↘</span>
                    </div>
                  )}
                </div>
              </a>
            </section>
          )}

          <section class="home-timeline-intro mb-6" aria-label={timelinePrelude.label}>
            <div class="home-timeline-intro__label">{timelinePrelude.label}</div>
            <p class="home-timeline-intro__desc">{timelinePrelude.desc}</p>
          </section>

          <div id="diary-description" class="sr-only">
            Entries are shown in reverse chronological order. {ITEMS_PER_PAGE}{" "}
            records per page, {sortedEntries.length} in total.
          </div>
          <div
            id="diary-content"
            role="feed"
            aria-label="Diary timeline"
            aria-describedby="diary-description"
            aria-live="polite"
            aria-busy="false"
          >
            <DiaryTimeline
              client:load
              initialEntries={initialParsedEntries}
              paginationInfo={paginationInfo}
            />
          </div>
          <QuickJumpNav
            mode="diary"
            headingSelector="#diary-content h2[id^='date-']"
            containerSelector="#diary-content"
          />
        </div>

        <BackToTopButton />
      </div>
    </section>
  </main>

  <Footer />
</Layout>
